# Encryption key is used to encrypt and decrypt the sensitive data stored
# in the database such as database credentials, secret keys, etc.
PBW_ENCRYPTION_KEY=""

# Database connection string for a PostgreSQL database where the pgbackweb
# will store its data.
PBW_POSTGRES_CONN_STRING=""

# The host on which the pgbackweb will listen for incoming HTTP requests.
PBW_LISTEN_HOST=""

# The port on which the pgbackweb will listen for incoming HTTP requests.
PBW_LISTEN_PORT=""

# Path prefix to use for all routes. If you set this to e.g. "/pgbackweb",
# the web interface will be available at http://<host>:<port>/pgbackweb
PBW_PATH_PREFIX=""

# Your timezone, this impacts logging, backup filenames and default timezone
# in the web interface.
TZ=""

# Public URL for OIDC redirect (required when SSO is enabled).
PBW_PUBLIC_URL=""

# Keycloak / OIDC (optional; optional SSO via Keycloak or any OIDC provider).
PBW_OIDC_ENABLED=""
PBW_OIDC_ISSUER=""
PBW_OIDC_CLIENT_ID=""
PBW_OIDC_CLIENT_SECRET=""

# Keycloak client IDs allowed for HTTP API Bearer auth (comma-separated).
PBW_API_OIDC_CLIENT_IDS="individual"

# Register active backup tasks in the in-process cron scheduler (default: true).
# Set false on staging so only manual runs are allowed.
PBW_SCHEDULED_BACKUPS_ENABLED=""

# Default retention for executions when backup.retention_days=0 (days).
PBW_EXECUTION_RETENTION_DAYS=""

# YAML file with restore API presets (source/targets for /api/v1/restores).
PBW_RESTORE_PRESETS_PATH="configs/restore-presets.yaml"

# YAML file with hosts and PostgreSQL cluster ports for DB discovery.
PBW_DISCOVERY_CONFIG_PATH="configs/discovery.yaml"

# Credentials used by discovery to list databases and register backup jobs.
PBW_DISCOVERY_PG_USER="pgwbackup"
PBW_DISCOVERY_SCHEDULED_ENABLED="true"
PBW_DISCOVERY_CRON_EXPRESSION="0 4 * * 0"
PBW_DISCOVERY_TIME_ZONE="Asia/Yekaterinburg"
